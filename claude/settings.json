{
  "env": {},
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git show*)",
      "Bash(git branch)",
      "Bash(git branch -a*)",
      "Bash(git branch -r*)",
      "Bash(git branch -v*)",
      "Bash(git branch --*)",
      "Bash(git tag)",
      "Bash(git tag -l*)",
      "Bash(git tag -n*)",
      "Bash(git tag --*)",
      "Bash(git ls-files*)",
      "Bash(git rev-parse*)",
      "Bash(git describe*)",
      "Bash(git shortlog*)",
      "Bash(git blame*)",
      "Bash(git stash list*)",
      "Bash(git remote)",
      "Bash(git remote -v*)",
      "Bash(git remote show*)",
      "Bash(git remote get-url*)",
      "Bash(git config --get*)",
      "Bash(git config --list*)",
      "Bash(git fetch --dry-run*)"
    ],
    "deny": []
  },
  "model": "opus[1m]",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'if [[ \"$PWD\" == \"$HOME/Development/ARMGDN\"* ]]; then cat \"$HOME/Development/ARMGDN/CLAUDE.md\"; fi'",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "ccstatusline",
    "padding": 0
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true
  },
  "effortLevel": "high",
  "tui": "fullscreen",
  "voice": {
    "enabled": true,
    "mode": "hold"
  },
  "skipWorkflowUsageWarning": true,
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": true,
  "mcpServers": {
    "context7": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "--prefix",
        "/tmp",
        "@upstash/context7-mcp@latest"
      ],
      "env": {}
    }
  }
}
