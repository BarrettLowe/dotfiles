{
  "env": {},
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git show*)",
      "Bash(git branch)",
      "Bash(git branch -a*)",
      "Bash(git branch -r*)",
      "Bash(git branch -v*)",
      "Bash(git branch --*)",
      "Bash(git tag)",
      "Bash(git tag -l*)",
      "Bash(git tag -n*)",
      "Bash(git tag --*)",
      "Bash(git ls-files*)",
      "Bash(git rev-parse*)",
      "Bash(git describe*)",
      "Bash(git shortlog*)",
      "Bash(git blame*)",
      "Bash(git stash list*)",
      "Bash(git remote)",
      "Bash(git remote -v*)",
      "Bash(git remote show*)",
      "Bash(git remote get-url*)",
      "Bash(git config --get*)",
      "Bash(git config --list*)",
      "Bash(git fetch --dry-run*)"
    ],
    "deny": []
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'if [[ \"$PWD\" == \"$HOME/Development/ARMGDN\"* ]]; then cat \"$HOME/Development/ARMGDN/CLAUDE.md\"; fi'",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Grep|Glob|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"/home/barrett-lowe/.claude/hooks/gitnexus/gitnexus-hook.cjs\"",
            "timeout": 10,
            "statusMessage": "Enriching with GitNexus graph context..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"/home/barrett-lowe/.claude/hooks/gitnexus/gitnexus-hook.cjs\"",
            "timeout": 10,
            "statusMessage": "Checking GitNexus index freshness..."
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash /home/barrett-lowe/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true
  },
  "skipAutoPermissionPrompt": true,
  "mcpServers": {
    "context7": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "--prefix",
        "/tmp",
        "@upstash/context7-mcp@latest"
      ],
      "env": {}
    }
  }
}
